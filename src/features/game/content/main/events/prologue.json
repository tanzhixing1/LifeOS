[
  {
    "id": "prologue_wake_up",
    "title": "雾莓镇的清晨",
    "presentation": "visualNovel",
    "backgroundId": "room_morning",
    "dialogue": [
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "晨光从斜斜的小窗照进来，落在梁上晾着的药草束上，把整间魔女小屋都晒出一点暖意。"
      },
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "木桌上摊着昨晚抄到一半的笔记，旧书压着几片卷边的叶子，杯底还留着草药茶微苦的香气。"
      },
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "透过窗子，雾莓镇还裹在轻雾里。石板路、低矮屋顶和远处的钟楼都像刚准备醒来。"
      },
      {
        "speakerId": "me",
        "speakerName": "我",
        "text": "今天就是第一天了。再紧张，也该像个真正的见习魔女那样出门。"
      },
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "门外传来瓷杯轻碰木盘的声音，有人显然比你更早开始了今天。"
      }
    ],
    "options": [
      {
        "text": "起身去看看",
        "effects": [
          {
            "type": "setFlag",
            "key": "prologue_started",
            "value": true
          }
        ],
        "next": {
          "eventId": "prologue_lilith_intro",
          "locationId": "home"
        }
      }
    ]
  },
  {
    "id": "prologue_lilith_intro",
    "title": "莉莉丝",
    "presentation": "visualNovel",
    "backgroundId": "room_morning",
    "characters": [
      {
        "id": "lilith",
        "name": "莉莉丝",
        "position": "right",
        "defaultSpriteId": "mentor_neutral",
        "defaultExpression": "平静"
      }
    ],
    "dialogue": [
      {
        "speakerId": "lilith",
        "speakerName": "莉莉丝",
        "spriteId": "mentor_neutral",
        "text": "终于醒了，亲爱的。我差点以为你打算把见习第一天也安排进梦里完成。"
      },
      {
        "speakerId": "narrator",
        "speakerName": "旁白",
        "text": "莉莉丝正靠在门边，手里端着一只浅口瓷杯。她看上去像刚散步回来，连晨雾都没舍得碰乱她的头发。"
      },
      {
        "speakerId": "me",
        "speakerName": "我",
        "text": "所以，从今天起就算正式开始了？"
      },
      {
        "speakerId": "lilith",
        "speakerName": "莉莉丝",
        "spriteId": "mentor_neutral",
        "text": "当然。真正的魔女生活不是坐在屋里把自己想得很了不起，而是走出去，认识小镇，接下委托，也让别人慢慢认识你。"
      },
      {
        "speakerId": "lilith",
        "speakerName": "莉莉丝",
        "spriteId": "mentor_neutral",
        "text": "你总得先学会和雾莓镇打招呼，它才会把日子一点点交给你。"
      }
    ],
    "options": [
      {
        "text": "听她安排今天",
        "effects": [
          {
            "type": "setFlag",
            "key": "met_lilith",
            "value": true
          },
          {
            "type": "setFlag",
            "key": "lilith_intro_seen",
            "value": true
          }
        ],
        "next": {
          "eventId": "prologue_first_choice",
          "locationId": "home"
        }
      }
    ]
  },
  {
    "id": "prologue_first_choice",
    "title": "今天想怎么开始",
    "presentation": "visualNovel",
    "backgroundId": "room_morning",
    "characters": [
      {
        "id": "lilith",
        "name": "莉莉丝",
        "position": "right",
        "defaultSpriteId": "mentor_neutral",
        "defaultExpression": "平静"
      }
    ],
    "dialogue": [
      {
        "speakerId": "lilith",
        "speakerName": "莉莉丝",
        "spriteId": "mentor_neutral",
        "text": "不过别急着摆出那种要和命运决斗的表情。第一天只需要一个还算像样的开头。"
      },
      {
        "speakerId": "lilith",
        "speakerName": "莉莉丝",
        "spriteId": "mentor_neutral",
        "text": "告诉我吧，今天的你，准备先当个认真的孩子、好奇的孩子，还是肚子饿的孩子？"
      }
    ],
    "options": [
