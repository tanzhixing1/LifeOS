    { "id": "grocery", "name": "杂货铺", "neighbors": ["home", "market"] },
    { "id": "church", "name": "圣殿 / 教堂", "neighbors": ["home", "market"] },
    { "id": "forest", "name": "魔物森林", "neighbors": ["market", "bar"] },
    { "id": "bar", "name": "酒吧", "neighbors": ["forest"] }
  ]
}
