        {
          "text": "翻开笔记",
          "effects": [{ "type": "advanceTime", "minutes": 30 }],
          "next": { "eventId": "demo_note", "locationId": "home" }
        },
        {
          "text": "听听门外的动静",
          "next": { "eventId": "demo_vn_morning", "locationId": "home" }
        }
      ]
    },
    {
      "id": "market_morning",
      "title": "市集",
      "paragraphs": ["市集里有人在卖香草，也有人在卖故事。你可以什么都不买，也可以留下些东西。"],
      "options": [
        {
          "text": "买早餐",
          "effects": [
            { "type": "walletDelta", "money": -5 },
            { "type": "vitalsDelta", "deltas": { "bodyStatus": 5 } },
            { "type": "advanceTime", "minutes": 30 }
          ],
          "next": { "eventId": "market_morning" }
        },
        {
          "text": "和摊主闲聊",
          "effects": [
            { "type": "addAttr", "key": "friendship", "value": 1 },
            { "type": "advanceTime", "minutes": 30 }
          ],
          "next": { "eventId": "market_morning" }
        },
        {
          "text": "离开",
          "route": "map"
        }
      ]
    },
    {
      "id": "grocery_shop",
      "title": "杂货铺",
      "paragraphs": ["货架上摆着小甜水、空白笔记本和包装过度的糖果。老板看起来很会推荐你买不需要的东西。"],
      "options": [
        {
          "text": "查看商品",
          "effects": [{ "type": "advanceTime", "minutes": 30 }],
          "next": { "eventId": "grocery_shop" }
        },
        {
          "text": "什么都不买",
          "route": "map"
        }
      ]
    },
    {
      "id": "church_pray",
      "title": "教堂",
