{
  "startEventId": "demo_start",
  "events": [
    {
      "id": "demo_start",
      "title": "清晨",
      "paragraphs": [
        "你推开窗时，雾莓镇还带着一点没醒透的安静。",
        "今天要做什么，先从小屋里慢慢想起。"
      ],
      "options": [
        {
          "text": "推开小屋的门",
          "next": { "eventId": "home_hut", "locationId": "home" }
        },
        {
          "text": "听听门外的动静",
          "next": { "eventId": "demo_vn_morning", "locationId": "home" }
        }
      ]
    },
    {
      "id": "demo_vn_morning",
      "title": "门外的声音",
      "presentation": "visualNovel",
      "backgroundId": "room_morning",
      "characters": [
        {
          "id": "mentor",
          "name": "莉莉丝",
          "position": "right",
          "defaultSpriteId": "mentor_neutral",
          "defaultExpression": "平静"
        }
      ],
      "dialogue": [
        { "speakerId": "mentor", "speakerName": "莉莉丝", "spriteId": "mentor_neutral", "text": "你醒得正好。" },
        { "speakerId": "mentor", "speakerName": "莉莉丝", "spriteId": "mentor_neutral", "text": "今天的雾看着比昨天轻一点。" },
        { "speakerId": "me", "speakerName": "我", "text": "也许是因为我终于把昨晚的事情收拾完了。" }
      ],
      "options": [
        {
          "text": "继续整理魔法笔记",
          "effects": [
            { "type": "setFlag", "key": "met_mentor", "value": true },
            { "type": "addAttr", "key": "focus", "value": 1 }
          ],
          "next": { "eventId": "demo_note", "locationId": "home" }
        },
        {
          "text": "去市集看看",
          "next": { "eventId": "market_morning", "locationId": "market" }
        }
      ]
    },
    {
      "id": "demo_room",
      "title": "房间",
      "paragraphs": ["屋里有淡淡的茶香。桌上摊着一页没写完的纸。"],
      "options": [
        {
          "text": "开始今天的练习",
          "effects": [{ "type": "addAttr", "key": "focus", "value": 1 }],
          "next": { "eventId": "home_hut", "locationId": "home" }
        },
        {
          "text": "再躺 5 分钟",
          "effects": [{ "type": "addAttr", "key": "stamina", "value": 1 }],
          "next": { "eventId": "home_hut", "locationId": "home" }
        }
      ]
    },
    {
      "id": "demo_note",
      "title": "笔记",
      "paragraphs": ["纸页上写着几行提醒：慢一点没关系，但别把今天浪费在发呆里。"],
      "options": [
        {
          "text": "记下一个目标",
          "effects": [
            { "type": "setFlag", "key": "goal_set", "value": true },
            { "type": "addAttr", "key": "focus", "value": 1 }
          ],
          "next": { "eventId": "demo_room", "locationId": "home" }
        },
        {
          "text": "合上笔记",
          "next": { "eventId": "home_hut", "locationId": "home" }
        }
      ]
    },
    {
      "id": "home_hut",
      "title": "魔女小屋",
      "paragraphs": ["你回到熟悉的小屋。窗边堆着没整理完的笔记，床看上去比任何大课题都更有说服力。"],
      "options": [
        {
          "text": "睡觉",
          "effects": [{ "type": "sleepToNextDay" }],
          "next": { "eventId": "home_hut" }
        },
        {
          "text": "出门",
          "route": "map"
        },
        {
          "text": "整理笔记",
          "effects": [
            { "type": "addAttr", "key": "focus", "value": 1 },
            { "type": "advanceTime", "minutes": 30 }
