        {
          "text": "找人聊天",
          "effects": [
            { "type": "addAttr", "key": "friendship", "value": 1 },
            { "type": "advanceTime", "minutes": 30 }
          ],
          "next": { "eventId": "bar_night" }
        },
        {
          "text": "离开",
          "route": "map"
        }
      ]
