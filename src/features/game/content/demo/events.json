      "paragraphs": ["林间有潮湿的泥土味，草叶边缘挂着雾。你看见几株能用的药草。"],
      "options": [
        {
          "text": "采药",
          "effects": [
            { "type": "addAttr", "key": "proficiency", "value": 1 },
            { "type": "vitalsDelta", "deltas": { "fatigue": 1 } },
            { "type": "advanceTime", "minutes": 30 }
          ],
          "next": { "eventId": "monster_forest" }
        },
        {
          "text": "不深入",
          "route": "map"
        }
      ]
    },
    {
      "id": "bar_night",
      "title": "酒吧",
      "paragraphs": ["夜色落下后，酒吧终于亮起灯。杯子碰撞声、笑声和秘密一起浮在空气里。"],
      "options": [
        {
          "text": "喝一杯",
          "effects": [
            { "type": "walletDelta", "money": -10 },
            { "type": "vitalsDelta", "deltas": { "intoxication": 1 } },
            { "type": "addAttr", "key": "charisma", "value": 1 },
            { "type": "advanceTime", "minutes": 30 }
